#!/usr/bin/env bash
# StableDAW pre-commit hook.
#
# Re-runs scripts/regenerate-docs.sh so the canonical user guide,
# the in-app copy under frontend/public, and (optionally) the
# Playwright screenshots all stay in sync with the source.
#
# Bypass with `git commit --no-verify` when you really need to.

set -e

repo_root="$(git rev-parse --show-toplevel)"
script="$repo_root/scripts/regenerate-docs.sh"

if [[ ! -x "$script" ]]; then
  echo "[pre-commit] scripts/regenerate-docs.sh missing or not executable — skipping docs regen."
  exit 0
fi

# Run under bash explicitly so this works on Windows git-bash hooks too.
bash "$script"
