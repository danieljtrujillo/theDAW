x,pt.y);}ctx.stroke();if(!isDown){let dx=(W/2-posX),dy=(H/2-posY),moved=false;if(Math.abs(dx)>0.2||Math.abs(dy)>0.2){posX+=dx*0.025;posY+=dy*0.025;moved=true;}else if(posX!==W/2||posY!==H/2){posX=W/2;posY=H/2;moved=true;}if(moved)window.parent.postMessage({type:'updateValue',id:'oivsvlg',valueX:posX/W,valueY:posY/H},'*');}if(isDown||Math.hypot(posX-W/2,posY-H/2)>0.2)trails.push({x:posX,y:posY,age:0});for(let i=trails.length-1;i>=0;i--){trails[i].age++;if(trails[i].age>25)trails.splice(i,1);}if(trails.length>1){ctx.lineCap='round';ctx.lineJoin='round';for(let i=0;i<trails.length-1;i++){let t1=trails[i],t2=trails[i+1],p=1-(t1.age/25);if(p<0)p=0;ctx.beginPath();ctx.moveTo(t1.x,t1.y);ctx.lineTo(t2.x,t2.y);ctx.strokeStyle='rgba(255,255,255,'+(p*0.9)+')';ctx.lineWidth=p*(dotR*2);ctx.stroke();}}ctx.beginPath();ctx.arc(posX,posY,dotR,0,Math.PI*2);ctx.fillStyle='#fff';ctx.shadowColor='#fff';ctx.shadowBlur=dotR*1.5+2;ctx.fill();ctx.shadowBlur=0;ctx.beginPath();ctx.arc(tX,tY,tR,0,Math.PI*2);if(toggled){let p=0.5+0.5*Math.sin(Date.now()/1500);let a=0.65+p*0.35;let r=Math.floor(80+p*70);let g=ctx.createRadialGradient(tX,tY,0,tX,tY,tR);g.addColorStop(0,'rgba('+r+',0,0,'+a+')');g.addColorStop(1,'rgba(10,0,0,'+a+')');ctx.fillStyle=g;ctx.fill();}else{ctx.strokeStyle='#fff';ctx.lineWidth=2;ctx.stroke();}requestAnimationFrame(loop);}loop();</script>", "transparentBackground": true, "x": 405.14580105963944, "borderColor": "transparent", "type": "CustomCode", "id": "oivsvlg", "value": 0.5, "blendMode": "difference", "isLocked": false}, {"id": "o6ygl31", "name": "button_drum pad_11", "type": "CustomCode", "variant": "Minimal", "x": 301.5975297342818, "y": 219.68294300251867, "width": 47.490659002504, "height": 48.69470866907793, "label": " ", "customCode": "<style>.ring-btn{width:100%;height:100%;border-radius:50%;background:transparent;border:2px solid transparent;cursor:pointer;box-sizing:border-box;transition:border-color 0.2s ease;outline:none;-webkit-appearance:none;}.ring-btn.activ