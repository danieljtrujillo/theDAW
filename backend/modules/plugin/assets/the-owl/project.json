(h-20,ny));});cvs.addEventListener('wheel',e=>{if(!act)return;e.preventDefault();act.z-=e.deltaY*0.0004;if(act.z<0.7)act.z=0.7;if(act.z>1.3)act.z=1.3;},{passive:false});function drw(){ctx.clearRect(0,0,w,h);ctx.strokeStyle='rgba(255,255,255,0.05)';ctx.lineWidth=1;for(let i=1;i<=4;i++){ctx.beginPath();ctx.arc(cx,cy,i*35,0,Math.PI*2);ctx.stroke();}ctx.fillStyle='rgba(255,255,255,0.8)';ctx.font='10px monospace';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('L',cx,cy);ctx.beginPath();ctx.moveTo(cx-6,cy);ctx.lineTo(cx-12,cy-3);ctx.lineTo(cx-12,cy+3);ctx.fillStyle='rgba(255,255,255,0.4)';ctx.fill();ctx.beginPath();ctx.arc(cx,cy,50,Math.PI-0.25,Math.PI+0.25);ctx.strokeStyle='rgba(255,255,255,0.15)';ctx.lineWidth=2;ctx.stroke();nds.forEach(n=>{const dx=cx-n.x;const dy=cy-n.y;ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(cx,cy);ctx.setLineDash([2,4]);ctx.strokeStyle='rgba(255,255,255,0.1)';ctx.stroke();ctx.setLineDash([]);const g=ctx.createLinearGradient(n.x,n.y,cx,cy);g.addColorStop(0,'rgba(255,255,255,0.4)');g.addColorStop(1,'rgba(255,255,255,0)');ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.quadraticCurveTo(n.x+dx*0.5-dy*0.3,n.y+dy*0.5+dx*0.3,cx,cy);ctx.strokeStyle=g;ctx.lineWidth=1.5;ctx.stroke();const rad=6*n.z;ctx.beginPath();ctx.arc(n.x,n.y,rad,0,Math.PI*2);ctx.fillStyle='#fff';ctx.fill();ctx.beginPath();ctx.arc(n.x,n.y,rad+4,0,Math.PI*2);ctx.strokeStyle='rgba(255,255,255,0.3)';ctx.lineWidth=1;ctx.stroke();const zp=(n.z-0.7)/0.6;if(zp>0.01){ctx.beginPath();ctx.arc(n.x,n.y,rad+8,-Math.PI/2,-Math.PI/2+(Math.PI*2*zp));ctx.strokeStyle='rgba(255,255,255,0.9)';ctx.stroke();}ctx.textAlign='left';ctx.fillStyle='rgba(255,255,255,0.5)';ctx.fillText(n.id+' Z:'+Math.round(zp*99),n.x+rad+14,n.y);});requestAnimationFrame(drw);}drw();</script>", "cornerRadius": 0, "effect": "none"}, {"y": 203.4833806859027, "height": 432.87015706806284, "name": "custom_kaoss_pad", "width": 443.86387434554973, "customCode": "<script>let W=window.innerWidth,H=window.innerHeight;const c=doc