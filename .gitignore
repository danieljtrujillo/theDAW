# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

*.ckpt
*.wav
wandb/*
*.out

.gradio
.DS_Store
*.safetensors
.claude
# Custom ignores
repomix-output.md
*.bak-*
.playwright-mcp/
.serena/
local_models.txt
grafting_day/frontend-graft-manifest.json
frontend.bak*/

# TypeScript incremental build cache — regenerated by tsc -b on every build,
# noisy in diffs, and machine-specific timestamps.
*.tsbuildinfo

# Node dependency folders — generated by npm/pnpm/yarn installs. Keep lockfiles
# committed, but never vendor package trees from frontend or sidecars.
node_modules/

# Local backup snapshots — never commit
_RECOVERY_BACKUP/


# Reference PDFs kept locally, not version-controlled (large binaries)
docs/*.pdf

# Local archive of superseded/scratch files (see archive/README.md) — not tracked
/archive/
.vite/
.orb_attachments/

# Generated exports (VJ renders, transcodes, PNG-sequence zips, etc.) — NEVER
# commit exports of any kind. The VJ exporter writes here by default.
/exports/

# Session changelogs — local dev notes, not version-controlled
/docs/changes/

# Loose capture stills & scratch media at repo root (mirror the *.png policy so
# ad-hoc .jpeg screenshots like shot01_*.jpeg never get committed). Anchored to
# root so frontend image assets are unaffected.
/*.jpeg
/*.jpg
/.tmp-shots/

# VS Code workspace files are per-user / machine-specific — never commit.
*.code-workspace

# Showcase assets are local-only (demo video, screenshots, scripts, raw media).
# Kept on disk but not shipped in everyone's clone.
/showcase/

# Root-level scratch artifacts (debug dumps, one-off harnesses, reference
# prototypes, personal media) stay local. Anchored to root so real assets
# elsewhere are unaffected.
/_*.json
/_*.py
/*.mp3
/dna-polyphonic-splice*.html

# Local audit artifacts: vulnerability details stay off the remote.
/CODEBASE_AUDIT_*.md
/audit-reports/

# Electron desktop shell — build artifacts + runtime logs (deps via node_modules/ above)
electron-ui/out/
electron-ui/release/
logs/
